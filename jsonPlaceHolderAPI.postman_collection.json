  "item": [
    {
      "name": "Getting a Resource",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response body\r",
              "let response = pm.response.json();\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Validate response schema\r",
              "pm.test(\"Response has correct schema\", function () {\r",
              "    pm.expect(response).to.have.property(\"userId\").that.is.a(\"number\");\r",
              "    pm.expect(response).to.have.property(\"id\").that.is.a(\"number\");\r",
              "    pm.expect(response).to.have.property(\"title\").that.is.a(\"string\");\r",
              "    pm.expect(response).to.have.property(\"body\").that.is.a(\"string\");\r",
              "});\r",
              "\r",
              "// Validate the correct resource is returned\r",
              "pm.test(\"Returned resource has id 1\", function () {\r",
              "    pm.expect(response.id).to.eql(1);\r",
              "});\r",
              "\r",
              "// Validate fields are not empty\r",
              "pm.test(\"Title and body are not empty strings\", function () {\r",
              "    pm.expect(response.title).to.not.be.empty;\r",
              "    pm.expect(response.body).to.not.be.empty;\r",
              "});\r",
              "\r",
              "// Validate userId is a positive number\r",
              "pm.test(\"userId is a positive number\", function () {\r",
              "    pm.expect(response.userId).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}posts/1",
          "host": [
