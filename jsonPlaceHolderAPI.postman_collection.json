      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response body\r",
              "const response = pm.response.json();\r",
              "\r",
              "// Status code test\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// Validate response schema\r",
              "pm.test(\"Response has correct schema\", function () {\r",
              "    pm.expect(response).to.have.property(\"title\").that.is.a(\"string\");\r",
              "    pm.expect(response).to.have.property(\"body\").that.is.a(\"string\");\r",
              "    pm.expect(response).to.have.property(\"userId\").that.is.a(\"number\");\r",
              "    pm.expect(response).to.have.property(\"id\").that.is.a(\"number\");\r",
              "});\r",
              "\r",
              "// Validate the created resource echoes back the sent data\r",
              "pm.test(\"Response contains the submitted title\", function () {\r",
              "    const requestBody = JSON.parse(pm.request.body.raw);\r",
              "    pm.expect(response.title).to.eql(requestBody.title);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains the submitted body\", function () {\r",
              "    const requestBody = JSON.parse(pm.request.body.raw);\r",
              "    pm.expect(response.body).to.eql(requestBody.body);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains the submitted userId\", function () {\r",
              "    const requestBody = JSON.parse(pm.request.body.raw);\r",
              "    pm.expect(response.userId).to.eql(requestBody.userId);\r",
              "});\r",
              "\r",
              "// Validate an ID was assigned to the new resource\r",
              "pm.test(\"New resource has an assigned id\", function () {\r",
              "    pm.expect(response.id).to.be.a(\"number\");\r",
              "    pm.expect(response.id).to.be.above(0);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
