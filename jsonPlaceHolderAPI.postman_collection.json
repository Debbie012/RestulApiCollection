    {
      "name": "Listing Resource",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse response body\r",
              "let response = pm.response.json();\r",
              "\r",
              "// Status code test\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Validate schema for all items\r",
              "pm.test(\"All items have correct schema\", function () {\r",
              "    response.forEach(function (item) {\r",
              "        pm.expect(item).to.have.property(\"userId\").that.is.a(\"number\");\r",
              "        pm.expect(item).to.have.property(\"id\").that.is.a(\"number\");\r",
              "        pm.expect(item).to.have.property(\"title\").that.is.a(\"string\");\r",
              "        pm.expect(item).to.have.property(\"body\").that.is.a(\"string\");\r",
              "    });\r",
              "});\r",
              "\r",
              "// Validate IDs are unique\r",
              "pm.test(\"All item IDs are unique\", function () {\r",
              "    const ids = response.map(function (item) { return item.id; });\r",
              "    const uniqueIds = [...new Set(ids)];\r",
              "    pm.expect(ids.length).to.eql(uniqueIds.length);\r",
              "});\r",
              "\r",
              "// Validate userId values are positive numbers\r",
              "pm.test(\"All userIds are positive numbers\", function () {\r",
              "    response.forEach(function (item) {\r",
              "        pm.expect(item.userId).to.be.above(0);\r",
              "    });\r",
              "});\r",
              "\r",
              "// Validate title and body are not empty strings\r",
              "pm.test(\"All items have non-empty title and body\", function () {\r",
              "    response.forEach(function (item) {\r",
              "        pm.expect(item.title).to.not.be.empty;\r",
              "        pm.expect(item.body).to.not.be.empty;\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
